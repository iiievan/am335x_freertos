                  <name>HSDIVIDER_CLKOUT3_DIV</name>
                  <description>Control the way mandatory clocks are managed.[see e_PRCM_MODULEMODE]</description>
                  <bitOffset>0</bitOffset>
                  <bitWidth>5</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>HSDIVIDER_CLKOUT3_DIVCHACK</name>
                  <description>bit: 5 (R)indicates that the change in divider HSDIVIDER_CLKOUT3_DIV value has taken effect</description>
                  <bitOffset>5</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>HSDIVIDER_CLKOUT3_GATE_CTRL</name>
                  <description>bit: 8 (RW)Control gating of HSDIVIDER CLKOUT3 [0x0 = autogate; 0x1 = force enabled;]</description>
                  <bitOffset>6</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>ST_HSDIVIDER_CLKOUT3</name>
                  <description>bit: 9 (R)HSDIVIDER CLKOUT3 status [0x0 = gated; 0x1 = enabled;]</description>
                  <bitOffset>7</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>HSDIVIDER_CLKOUT3_PWDN</name>
                  <description>bit: 12 (RW)Automatic power down for HSDIVIDER M6 divider [0x0 = Keep powered on; 0x1 = Automatically power down;]</description>
                  <bitOffset>8</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
          </registers>
        </peripheral>
        <peripheral>
          <name>PRM_CEFUSE</name>
          <description>Power Reset Module - CEFUSE</description>
          <baseAddress>0x44E01200</baseAddress>
          <groupName>Power Reset Modules</groupName>
          <registers>
            <register>
              <name>CEFUSE_PWRSTCTRL</name>
              <addressOffset>0x00</addressOffset>
              <description>CEFUSE_PWRSTCTRL Register</description>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <fields>
                <field>
                  <name>PowerState</name>
                  <description>bit: 0,1 (RW) Power state control [see e_CEFUSE_PWRSTATE_CTRL]</description>
                  <bitOffset>0</bitOffset>
                  <bitWidth>2</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>LowPowerStateChange</name>
                  <description>bit: 4 (RW) Power state change request when domain has already performed a sleep transition [0x0 = Do not request; 0x1 = Request a low power state change]</description>
                  <bitOffset>2</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
            <register>
              <name>CEFUSE_PWRSTST</name>
              <addressOffset>0x04</addressOffset>
              <description>CEFUSE_PWRSTST Register</description>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <fields>
                <field>
                  <name>PowerStateSt</name>
                  <description>bit: 0,1 (R)Current Power State Status [see e_CEFUSE_PWRSTST]</description>
                  <bitOffset>0</bitOffset>
                  <bitWidth>2</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>LogicStateSt</name>
                  <description>bit: 2 (R)Logic state status [0x0 = logic in domain OFF; 0x1 = logic in domain ON]</description>
                  <bitOffset>2</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>InTransition</name>
                  <description>bit: 20 (R)Domain transition status [0x0 = No on-going transition; 0x1 = transition is in progress.]</description>
                  <bitOffset>3</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>LastPowerStateEntered</name>
                  <description>bit: 24,25 (RW)Last low power state entered.Set to 0x3 upon write of the same only. [0x0 = OFF; 0x1 = ON]</description>
                  <bitOffset>4</bitOffset>
                  <bitWidth>2</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
          </registers>
        </peripheral>
        <peripheral>
          <name>PRM_DEVICE</name>
          <description>Power Reset Module - Device</description>
          <baseAddress>0x44E00F00</baseAddress>
          <groupName>Power Reset Modules</groupName>
          <registers>
            <register>
              <name>PRM_RSTCTRL</name>
              <addressOffset>0x00</addressOffset>
              <description>PRM_RSTCTRL Register</description>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <fields>
                <field>
                  <name>RST_GLOBAL_WARM_SW</name>
                  <description>bit: 0 (W) Global WARM software reset control. [0x0 = Global COLD; 0x1 = Asserts a global COLD software reset.]</description>
                  <bitOffset>0</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>RST_GLOBAL_COLD_SW</name>
                  <description>bit: 1 (W) Global COLD software reset control. [0x0 = Global warm software reset is cleared.; 0x1 = Asserts a global warm software reset.]</description>
                  <bitOffset>1</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
            <register>
              <name>PRM_RSTTIME</name>
              <addressOffset>0x04</addressOffset>
              <description>PRM_RSTTIME Register</description>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <fields>
                <field>
                  <name>RSTTIME1</name>
                  <description>(Power domain) reset duration 2 (number of CLK_M_OSC clockcycles)</description>
                  <bitOffset>0</bitOffset>
                  <bitWidth>8</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>RSTTIME2</name>
                  <description>(Global) reset duration 1 (number of CLK_M_OSC clock cycles)</description>
                  <bitOffset>8</bitOffset>
                  <bitWidth>5</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
            <register>
              <name>PRM_RSTST</name>
              <addressOffset>0x08</addressOffset>
              <description>PRM_RSTST Register</description>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <fields>
                <field>
                  <name>GLOBAL_COLD_RST</name>
                  <description>bit: 0 (RW) Power-on (cold) reset event [warm reset insensitive] [0x0 = No power-on reset.; 0x1 = Power-on reset has occurred.]</description>
                  <bitOffset>0</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>GLOBAL_WARM_SW_RS</name>
                  <description>bit: 1 (RW) Global warm software reset event [warm reset insensitive] [0x0 = No global warm SW reset; 0x1 = Global warm SW reset has occurred.]</description>
                  <bitOffset>1</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>WDT1_RST</name>
                  <description>bit: 4 (RW) Watchdog1 timer reset event. [0x0 = No watchdog reset.; 0x1 = watchdog reset has occurred.]</description>
                  <bitOffset>2</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>EXTERNAL_WARM_RST</name>
                  <description>bit: 5 (RW) External warm reset event [warm reset insensitive] [0x0 = No global warm reset.; 0x1 = Global external warm reset has occurred.]</description>
                  <bitOffset>3</bitOffset>
                  <bitWidth>2</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>ICEPICK_RST</name>
                  <description>bit: 9 (RW) IcePick reset event. [0x0 = No ICEPICK reset.; 0x1 = IcePick reset has occurred.]</description>
                  <bitOffset>5</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
            <register>
              <name>PRM_SRAM_COUNT</name>
              <addressOffset>0x0C</addressOffset>
              <description>PRM_SRAM_COUNT Register</description>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <fields>
                <field>
                  <name>PCHARGECNT_VALUE</name>
                  <description>Delay between de-assertion of standby_rta_ret_on and standby_rta_ret_good. Counting on system clock.Target is 600ns.</description>
                  <bitOffset>0</bitOffset>
                  <bitWidth>6</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>VSETUPCNT_VALUE</name>
                  <description>SRAM LDO rampup time from retention to active mode.The duration is computed as 8 x NbCycles of system clock cycles.Target is 30us.</description>
                  <bitOffset>6</bitOffset>
                  <bitWidth>8</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>SLPCNT_VALUE</name>
                  <description>Delay between retention/off assertion of last SRAM bank and SRAMALLRET signal to LDO is driven high. Counting on system clock.Target is 2us.</description>
                  <bitOffset>14</bitOffset>
                  <bitWidth>8</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>StartUp_Count</name>
                  <description>bit: 24.31 (RW) Determines the start-up duration of SRAM and ABB LDO.The duration is computed as 16 x NbCycles of system clock cycles.Target is 50us.</description>
                  <bitOffset>22</bitOffset>
                  <bitWidth>8</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
            <register>
              <name>PRM_LDO_SRAM_CORE_SETUP</name>
              <addressOffset>0x10</addressOffset>
              <description>PRM_LDO_SRAM_CORE_SETUP Register</description>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <fields>
                <field>
                  <name>DISABLE_RTA_EXPORT</name>
                  <description>bit: 0 (RW) Control for HD memory RTA feature. [0x0 = RTA_ENABLED; 0x1 = RTA_DISABLED]</description>
                  <bitOffset>0</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>ABBOFF_ACT_EXPORT</name>
                  <description>bit: 1 (RW) Determines whether SRAMNWA is supplied by VDDS or VDDAR during active mode. [0x0 = SRAMNWA supplied with VDDS; 0x1 = SRAMNW_ACT_VDDASRAMNWA supplied with VDDAR]</description>
                  <bitOffset>1</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>ABBOFF_SLEEP_EXPORT</name>
                  <description>bit: 2 (RW) Determines whether SRAMNWA is supplied by VDDS or VDDAR during deep-sleep. [0x0 = SRAMNWA supplied with VDDS; 0x1 = SRAMNW_ACT_VDDASRAMNWA supplied with VDDAR]</description>
                  <bitOffset>2</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>ENFUNC1_EXPORT</name>
                  <description>bit: 3 (RW) ENFUNC1 input of SRAM LDO. [0x0 = Short_prot_disabled; 0x1 = Short_prot_enabled]</description>
                  <bitOffset>3</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>ENFUNC2_EXPORT</name>
                  <description>bit: 4 (RW) ENFUNC2 input of SRAM LDO. [0x0 = Ext_cap; 0x1 = No_ext_cap]</description>
                  <bitOffset>4</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>ENFUNC3_EXPORT</name>
                  <description>bit: 5 (RW) ENFUNC3 input of SRAM LDO. [0x0 = Sub_regul_disabled; 0x1 = Sub_regul_enabled]</description>
                  <bitOffset>5</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>ENFUNC4</name>
                  <description>bit: 6 (RW) ENFUNC4 input of SRAM LDO. [0x0 = Ext_clock; 0x1 = No_ext_clock]</description>
                  <bitOffset>6</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>ENFUNC5</name>
                  <description>bit: 7 (RW) ENFUNC5 input of SRAM LDO. [0x0 = One_step; 0x1 = Two_step]</description>
                  <bitOffset>7</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>AIPOFF</name>
                  <description>bit: 8 (RW) Override on AIPOFF input of SRAM LDO. [0x0 = AIPOFF signal is not overriden; 0x1 = AIPOFF signal is overriden to '1'.]</description>
                  <bitOffset>8</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
            <register>
              <name>PRM_LDO_SRAM_CORE_CTRL</name>
              <addressOffset>0x14</addressOffset>
              <description>PRM_LDO_SRAM_CORE_CTRL Register</description>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <fields>
                <field>
                  <name>RETMODE_ENABLE</name>
                  <description>bit: 0 (RW) Control if the SRAM LDO retention mode is used or not. [0x0 = Disabled; 0x1 = Enabled]</description>
                  <bitOffset>0</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>SRAMLDO_STATUS</name>
                  <description>bit: 8 (R) SRAMLDO status [0x0 = ACTIVE; 0x1 = RETENTION]</description>
                  <bitOffset>1</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>SRAM_IN_TRANSITION</name>
                  <description>bit: 9 (R) Status indicating SRAM LDO state machine state. [0x0 = IDLE; 0x1 = IN_TRANSITION]</description>
                  <bitOffset>2</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
            <register>
              <name>PRM_LDO_SRAM_MPU_SETUP</name>
              <addressOffset>0x18</addressOffset>
              <description>PRM_LDO_SRAM_MPU_SETUP Register</description>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <fields>
                <field>
                  <name>DISABLE_RTA_EXPORT</name>
                  <description>bit: 0 (RW) Control for HD memory RTA feature. [0x0 = RTA_ENABLED; 0x1 = RTA_DISABLED]</description>
                  <bitOffset>0</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>ABBOFF_ACT_EXPORT</name>
                  <description>bit: 1 (RW) Determines whether SRAMNWA is supplied by VDDS or VDDAR during active mode. [0x0 = SRAMNWA supplied with VDDS; 0x1 = SRAMNW_ACT_VDDASRAMNWA supplied with VDDAR]</description>
                  <bitOffset>1</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>ABBOFF_SLEEP_EXPORT</name>
                  <description>bit: 2 (RW) Determines whether SRAMNWA is supplied by VDDS or VDDAR during deep-sleep. [0x0 = SRAMNWA supplied with VDDS; 0x1 = SRAMNW_ACT_VDDASRAMNWA supplied with VDDAR]</description>
                  <bitOffset>2</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>ENFUNC1_EXPORT</name>
                  <description>bit: 3 (RW) ENFUNC1 input of SRAM LDO. [0x0 = Short_prot_disabled; 0x1 = Short_prot_enabled]</description>
                  <bitOffset>3</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>ENFUNC2_EXPORT</name>
                  <description>bit: 4 (RW) ENFUNC2 input of SRAM LDO. [0x0 = Ext_cap; 0x1 = No_ext_cap]</description>
                  <bitOffset>4</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>ENFUNC3_EXPORT</name>
                  <description>bit: 5 (RW) ENFUNC3 input of SRAM LDO. [0x0 = Sub_regul_disabled; 0x1 = Sub_regul_enabled]</description>
                  <bitOffset>5</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>ENFUNC4</name>
                  <description>bit: 6 (RW) ENFUNC4 input of SRAM LDO. [0x0 = Ext_clock; 0x1 = No_ext_clock]</description>
                  <bitOffset>6</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>ENFUNC5</name>
                  <description>bit: 7 (RW) ENFUNC5 input of SRAM LDO. [0x0 = One_step; 0x1 = Two_step]</description>
                  <bitOffset>7</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>AIPOFF</name>
                  <description>bit: 8 (RW) Override on AIPOFF input of SRAM LDO. [0x0 = AIPOFF signal is not overriden; 0x1 = AIPOFF signal is overriden to '1'.]</description>
                  <bitOffset>8</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
            <register>
              <name>PRM_LDO_SRAM_MPU_CTRL</name>
              <addressOffset>0x1C</addressOffset>
              <description>PRM_LDO_SRAM_MPU_CTRL Register</description>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <fields>
                <field>
                  <name>RETMODE_ENABLE</name>
                  <description>bit: 0 (RW) Control if the SRAM LDO retention mode is used or not. [0x0 = Disabled; 0x1 = Enabled]</description>
                  <bitOffset>0</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>SRAMLDO_STATUS</name>
                  <description>bit: 8 (R) SRAMLDO status [0x0 = ACTIVE; 0x1 = RETENTION]</description>
                  <bitOffset>1</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>SRAM_IN_TRANSITION</name>
