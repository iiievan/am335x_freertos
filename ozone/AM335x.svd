                </field>
              </fields>
            </register>
            <register>
              <name>RHR</name>
              <addressOffset>0x00</addressOffset>
              <description>RHR Register</description>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <fields>
                <field>
                  <name>RHR</name>
                  <description>Receive holding register..[Value 0 to FFh.]</description>
