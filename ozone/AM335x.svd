                  <bitWidth>2</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>LogicRETState</name>
                  <description>bit: 2 (RW) Logic state when power domain is RETENTION [0x0 = logic_off; 0x1 = logic_ret]</description>
                  <bitOffset>2</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>LowPowerStateChange</name>
                  <description>bit: 4 (RW) Power state change request when domain has already performed a sleep transition [0x0 = Do not request; 0x1 = Request a low power state change]</description>
                  <bitOffset>3</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>GFX_MEM_RETState</name>
                  <description>bit: 6 (RW)</description>
                  <bitOffset>4</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>GFX_MEM_ONState</name>
                  <description>bit: 17,18 (R) GFX memory state when domain is ON.</description>
                  <bitOffset>5</bitOffset>
                  <bitWidth>2</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
            <register>
              <name>RM_GFX_RSTCTRL</name>
              <addressOffset>0x04</addressOffset>
              <description>RM_GFX_RSTCTRL Register</description>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <fields>
                <field>
                  <name>GFX_RST</name>
                  <description>bit: 0 (RW) GFX domain local reset control for (SGX 530) [0x0 = CLEAR; 0x1 = ASSERT]</description>
                  <bitOffset>0</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
            <register>
              <name>PM_GFX_PWRSTST</name>
              <addressOffset>0x10</addressOffset>
              <description>PM_GFX_PWRSTST Register</description>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <fields>
                <field>
                  <name>PowerStateSt</name>
                  <description>bit: 0,1 (R)Current Power State Status [see e_GFX_PWRSTST]</description>
                  <bitOffset>0</bitOffset>
                  <bitWidth>2</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>LogicStateSt</name>
                  <description>bit: 2 (R)Logic state status [0x0 = logic in domain OFF; 0x1 = logic in domain ON]</description>
                  <bitOffset>2</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>GFX_MEM_StateSt</name>
                  <description>bit: 4,5 (R)GFX memory state status [see e_GFX_MEMSTST]</description>
                  <bitOffset>3</bitOffset>
                  <bitWidth>2</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>InTransition</name>
                  <description>bit: 20 (R)Domain transition status [0x0 = No on-going transition on power domain; 0x1 = Power domain transition is in progress]</description>
                  <bitOffset>5</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
            <register>
              <name>RM_GFX_RSTST</name>
              <addressOffset>0x14</addressOffset>
              <description>RM_GFX_RSTST Register</description>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <fields>
                <field>
                  <name>GFX_RST</name>
                  <description>bit: 0 (RW) GFX Domain Logic Reset [0x0 = RESET_NO; 0x1 = RESET_YES]</description>
                  <bitOffset>0</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
          </registers>
        </peripheral>
