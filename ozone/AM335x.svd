                  <bitWidth>8</bitWidth>
                  <access>read-only</access>
                </field>
              </fields>
            </register>
            <register>
              <name>DLL</name>
              <addressOffset>0x00</addressOffset>
              <description>DLL Register</description>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <fields>
                <field>
                  <name>CLOCK_LSB</name>
                  <description>Divisor latches low.Stores the 8 LSB divisor value.[Value 0 to FFh.]</description>
                  <bitOffset>0</bitOffset>
                  <bitWidth>8</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
            <register>
              <name>IER_IRDA</name>
              <addressOffset>0x04</addressOffset>
              <description>IER_IRDA Register</description>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <fields>
                <field>
                  <name>RHRIT</name>
                  <description>bit: 0 (RW) RHR interrupt [0x0 = disable; 0x1 = enable ]</description>
                  <bitOffset>0</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>THRIT</name>
                  <description>bit: 1 (RW) THR interrupt [0x0 = disable; 0x1 = enable ]</description>
                  <bitOffset>1</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>LASTRXBYTEIT</name>
                  <description>bit: 2 (RW) last byte of frame in RX FIFO interrupt [0x0 = disable; 0x1 = enable ]</description>
                  <bitOffset>2</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>RXOVERRUNIT</name>
                  <description>bit: 3 (RW) RX overrun interrupt [0x0 = disable; 0x1 = enable ]</description>
                  <bitOffset>3</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>STSFIFOTRIGIT</name>
                  <description>bit: 4 (RW) status FIFO trigger level interrupt [0x0 = disable; 0x1 = enable ]</description>
                  <bitOffset>4</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>TXSTATUSIT</name>
                  <description>bit: 5 (RW) TX status interrupt [0x0 = disable; 0x1 = enable ]</description>
                  <bitOffset>5</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>LINESTSIT</name>
                  <description>bit: 6 (RW) receiver line status interrupt [0x0 = disable; 0x1 = enable ]</description>
                  <bitOffset>6</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>EOFIT</name>
                  <description>bit: 7 (RW) received EOF interrupt [0x0 = disable; 0x1 = enable ]</description>
                  <bitOffset>7</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
