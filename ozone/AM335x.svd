                  <bitOffset>2</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
          </registers>
        </peripheral>
        <peripheral>
          <name>PRM_GFX</name>
          <description>Power Reset Module - GFX</description>
          <baseAddress>0x44E01100</baseAddress>
